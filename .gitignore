# ──────────────────────────────────────────────────────────────
# Secrets — NEVER commit
# ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# JWT / cert / key material
*.pem
*.key
*.crt
*.pfx
secrets/

# ──────────────────────────────────────────────────────────────
# Node / NPM
# ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json.bak

# ──────────────────────────────────────────────────────────────
# Build output
# ──────────────────────────────────────────────────────────────
dist/
build/
.next/
out/
.vite/
.cache/
.parcel-cache/
coverage/
*.tsbuildinfo

# ──────────────────────────────────────────────────────────────
# User uploads (keep folder structure via .gitkeep)
# ──────────────────────────────────────────────────────────────
backend/public/uploads/products/*
!backend/public/uploads/products/.gitkeep

# ──────────────────────────────────────────────────────────────
# IDE / OS
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────
logs/
*.log

# ──────────────────────────────────────────────────────────────
# Local SQL dumps
# ──────────────────────────────────────────────────────────────
*.bak
*.sqlbak
*.mdf
*.ldf
